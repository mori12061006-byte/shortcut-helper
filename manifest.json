{
  "manifest_version": 3,
  "name": "Shortcut Helper",
  "version": "1.0.0",
  "description": "アプリごとのショートカットキー一覧をサイドバーで確認・管理できます",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "action": {
    "default_title": "Shortcut Helper を開く",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
